{
  "name": "@lerobot-viewer/reader",
  "version": "0.1.0",
  "description": "Node.js Parquet reader for LeRobot datasets",
  "license": "MIT",
  "author": "yangxinlin",
  "keywords": [
    "lerobot",
    "robotics",
    "parquet",
    "hugging-face",
    "dataset"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhemuse/lerobot-viewer.git",
    "directory": "packages/reader"
  },
  "homepage": "https://github.com/zhemuse/lerobot-viewer/tree/main/packages/reader",
  "bugs": {
    "url": "https://github.com/zhemuse/lerobot-viewer/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hyparquet": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.2"
  }
}
